# E2E Test Configuration
#
# Copy this file to `.env.e2e.local` (gitignored) and fill in real values.
# Used by playwright.config.ts and tests/e2e/specs/*.spec.ts.

# Target environment. Override on the command line for prod:
#   E2E_BASE_URL=https://splintfactory.com npm run test:e2e
E2E_BASE_URL=http://splintserver.local:3000

# Member-level test user. Must belong to the test organization below.
E2E_USER_EMAIL=jon+localtester@splintfactory.com
E2E_USER_PASSWORD=replace-me

# Organization that owns all test-created data. Used by the cleanup script
# to find and remove e2e jobs. Create this org in the UI before running tests.
E2E_ORG_NAME=Automated Test Clinic

# Design the sanity test targets. Must match Design.name in the database.
E2E_DESIGN_NAME=Infinity Flex
