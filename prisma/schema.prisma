generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id                        String                    @id @default(cuid())
  name                      String                    @unique
  description               String?
  isActive                  Boolean                   @default(true)
  screenLockTimeoutMinutes  Int                       @default(1)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  apiKeys         ApiKey[]
  designJobs      DesignJob[]
  invitationLinks InvitationLink[]
  users           User[]
  visibleDesigns  OrganizationDesign[]
  clientDevices   ClientDevice[]
}

model User {
  id                   String                    @id @default(cuid())
  name                 String?
  email                String                    @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  organizationId       String?
  role                 UserRole                  @default(MEMBER)
  invitedByUserId      String?
  invitationAcceptedAt DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  createdApiKeys       ApiKey[]                  @relation("CreatedApiKeys")
  createdDesignJobs    DesignJob[]               @relation("CreatedDesignJobs")
  usedInvitation       InvitationLink?           @relation("InvitationUsage")
  createdInvitations   InvitationLink[]          @relation("InvitationCreator")
  createdDesigns       Design[]
  createdLinks         Link[]
  sessions             Session[]
  invitedBy            User?                     @relation("UserInvitations", fields: [invitedByUserId], references: [id])
  invitedUsers         User[]                    @relation("UserInvitations")
  organization         Organization?             @relation(fields: [organizationId], references: [id])
  operatingDevices     ClientDevice[]            @relation("DeviceOperator")
  authorizedChallenges ClientAuthChallenge[]     @relation("ChallengeAuthorizer")
  printedJobs          PrintJob[]                @relation("PrintOperator")
  reviewedPrints       PrintJob[]                @relation("PrintReviewer")
  actorEvents          AuditEvent[]              @relation("AuditActor")
  targetEvents         AuditEvent[]              @relation("AuditTarget")
  passwordResetTokens  PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model InvitationLink {
  id              String       @id @default(cuid())
  token           String       @unique @default(cuid())
  email           String?
  expiresAt       DateTime
  usedAt          DateTime?
  organizationId  String
  createdByUserId String
  usedByUserId    String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  usedBy          User?        @relation("InvitationUsage", fields: [usedByUserId], references: [id])
  createdBy       User         @relation("InvitationCreator", fields: [createdByUserId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])
}

model Design {
  id                     String                    @id @default(cuid())
  name                   String                    @unique
  algorithmName          String
  inputParameterSchema   String
  shortDescription       String?
  isActive               Boolean                   @default(true)
  previewImage           Bytes?
  previewImageContentType    String?
  previewImageUpdatedAt      DateTime?
  measurementImage           Bytes?
  measurementImageContentType String?
  measurementImageUpdatedAt   DateTime?
  creatorId              String
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @default(now()) @updatedAt
  designJobs             DesignJob[]               @relation("DesignJobs")
  organizations          OrganizationDesign[]
  creator                User                      @relation(fields: [creatorId], references: [id])

  @@map("NamedGeometry")
}

model OrganizationDesign {
  organizationId  String
  designId        String
  createdAt       DateTime      @default(now())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  design          Design        @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@id([organizationId, designId])
  @@map("OrganizationGeometry")
}

model ApiKey {
  id             String        @id @default(cuid())
  name           String
  keyHash        String        @unique
  permissions    String
  organizationId String?
  isActive       Boolean       @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime      @default(now())
  createdBy      String
  creator        User          @relation("CreatedApiKeys", fields: [createdBy], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model DesignJob {
  id                    String        @id @default(cuid())
  designId              String
  creatorId             String
  owningOrganizationId  String
  createdAt             DateTime      @default(now())
  inputParameters       String
  processStartedAt      DateTime?
  processCompletedAt    DateTime?
  isProcessSuccessful   Boolean       @default(false)
  isEnabled             Boolean       @default(true)
  isDebugRequest        Boolean       @default(false)
  jobNote               String?
  jobLabel              String?
  objectId              String?       @unique
  objectIdGeneratedAt   DateTime?
  meshFileContents      Bytes?
  meshFileName          String?
  meshBlobUrl           String?
  meshBlobPathname      String?
  printFileContents     Bytes?
  printFileName         String?
  printBlobUrl          String?
  printBlobPathname     String?
  processingLog         String?
  meshMetadata          String?
  owningOrganization    Organization  @relation(fields: [owningOrganizationId], references: [id])
  creator               User          @relation("CreatedDesignJobs", fields: [creatorId], references: [id])
  design                Design        @relation("DesignJobs", fields: [designId], references: [id])
  printJobs             PrintJob[]

  @@map("GeometryProcessingQueue")
}

model PrintJob {
  id                  String      @id @default(cuid())
  designJobId         String
  printStartedAt      DateTime?
  printCompletedAt    DateTime?
  isPrintSuccessful   Boolean     @default(false)
  printNote           String?
  printAcceptance     String?
  isEnabled           Boolean     @default(true)
  createdAt           DateTime    @default(now())
  progress            Float?
  progressLastReportAt DateTime?
  logs                String?
  printedByUserId     String?
  acceptedByUserId    String?
  printerSerial       String?
  designJob           DesignJob   @relation(fields: [designJobId], references: [id])
  printedBy           User?       @relation("PrintOperator", fields: [printedByUserId], references: [id])
  acceptedBy          User?       @relation("PrintReviewer", fields: [acceptedByUserId], references: [id])
  printer             Printer?    @relation(fields: [printerSerial], references: [serial])

  @@map("PrintQueue")
}

enum UserRole {
  SYSTEM_ADMIN
  ORG_ADMIN
  MEMBER
}

enum LinkType {
  EXTERNAL_URL
  HOSTED_FILE
}

model SystemSettings {
  id                        String   @id @default("system_settings")
  maintenanceModeEnabled    Boolean  @default(false)
  maintenanceMessage        String?
  maintenanceModeUpdatedAt  DateTime @default(now()) @updatedAt
}

model Link {
  id          String         @id @default(cuid())
  shortcode   String         @unique
  linkType    LinkType
  linkTarget  String
  title       String?
  isActive    Boolean        @default(true)
  clickCount  Int            @default(0)
  createdBy   String
  createdAt   DateTime       @default(now())
  creator     User           @relation(fields: [createdBy], references: [id])
  activity    LinkActivity[]

  @@index([shortcode])
}

model LinkActivity {
  id           String   @id @default(cuid())
  linkId       String
  ipAddress    String?
  userAgent    String?
  referer      String?
  visitTime    DateTime @default(now())
  link         Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([visitTime])
}

model ClientDevice {
  id                  String               @id // UUID generated by the client
  name                String               // hostname or user-assigned name
  organizationId      String?              // null until first QR approval assigns device to org
  currentOperatorId   String?
  operatorValidatedAt DateTime?
  lastSeenAt          DateTime             @default(now())
  createdAt           DateTime             @default(now())
  organization        Organization?        @relation(fields: [organizationId], references: [id])
  currentOperator     User?                @relation("DeviceOperator", fields: [currentOperatorId], references: [id])
  authChallenges      ClientAuthChallenge[]
  printers            Printer[]
}

model ClientAuthChallenge {
  id                 String    @id @default(cuid())
  deviceId           String
  expiresAt          DateTime
  authorizedByUserId String?
  authorizedAt       DateTime?
  exchangeToken      String?   @unique // single-use token for session exchange
  exchangedAt        DateTime? // marks token as consumed
  createdAt          DateTime  @default(now())
  device             ClientDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  authorizedBy       User?        @relation("ChallengeAuthorizer", fields: [authorizedByUserId], references: [id])

  @@index([deviceId])
  @@index([exchangeToken])
}

model AuditEvent {
  id              String    @id @default(cuid())
  timestamp       DateTime  @default(now())
  eventType       String    // e.g. "USER_REGISTERED", "EMAIL_SENT", "EMAIL_VERIFIED"
  channel         String    // e.g. "AUTH", "EMAIL", "SYSTEM", "BILLING", "PRINT"
  actorId         String?   // user who triggered it (null for system events)
  targetUserId    String?   // user being acted upon
  organizationId  String?
  metadata        Json?     // flexible event-specific data
  actor           User?     @relation("AuditActor", fields: [actorId], references: [id])
  targetUser      User?     @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([eventType])
  @@index([channel])
  @@index([actorId])
  @@index([targetUserId])
  @@index([organizationId])
  @@index([timestamp])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

model Printer {
  serial          String            @id // Bambu serial, globally unique
  model           String            // "P1S", "X1C", etc.
  name            String?           // user-friendly name
  deviceId        String?           // which ClientDevice it's currently attached to
  lastSnapshotAt  DateTime?
  createdAt       DateTime          @default(now())
  device          ClientDevice?     @relation(fields: [deviceId], references: [id])
  snapshots       PrinterSnapshot[]
  printJobs       PrintJob[]
}

model PrinterSnapshot {
  id              String    @id @default(cuid())
  printerSerial   String
  deviceId        String    // denormalized -- which device captured this
  firmware        String
  modules         Json?     // { ota, ams, ahb, mc } versions
  amsConfig       Json?     // tray info, humidity
  networkIp       String?
  activeHmsErrors Json?     // any active HMS errors at capture time
  funField        String?   // raw hex for dev-mode analysis
  rawReport       Json?     // full pushall response for future mining
  capturedAt      DateTime  @default(now())
  printer         Printer   @relation(fields: [printerSerial], references: [serial])

  @@index([printerSerial, capturedAt])
}
